# ─────────────────────────────────────────────────────────────────────────────
# Server runtime configuration — server infrastructure only.
#
# Game rules (tickRate, world size, player speed, etc.) are defined in
# src/shared/gameConfig.json, embedded into the binary at build time,
# and shared with the TypeScript client.
#
# Values here take priority over embedded gameConfig.json defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Network bind ─────────────────────────────────────────────────────────────
PORT=8108
HOST=0.0.0.0

# ─── Connection limits ────────────────────────────────────────────────────────
MAX_CONNECTIONS=12000
EVENT_CHANNEL_SIZE=100000
SEND_CHANNEL_SIZE=2048

# ─── Worker pools (0 = auto-detect CPU count) ────────────────────────────────
WORKERS=0
BROADCAST_WORKERS=0

# ─── WebSocket buffers ───────────────────────────────────────────────────────
READ_BUFFER_SIZE=4096
WRITE_BUFFER_SIZE=4096

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Max messages per second per client
RATE_LIMIT_MSG_SEC=120
RATE_LIMIT_BURST=20

# ─── Go runtime tuning ────────────────────────────────────────────────────────
# Reduce GC frequency for high-throughput workloads (default is 100)
GOGC=800
# CPU cores to use (0 = all available)
GOMAXPROCS=0
# Hard memory cap — uncomment to enable
# GOMEMLIMIT=2GiB
# ─── Monitoring external ports ────────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin